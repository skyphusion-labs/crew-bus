# crew-bus Worker — wrangler config example.
# Copy to wrangler.toml and fill D1 database_id after: wrangler d1 create crew-bus
#
# Production config is NOT committed. CI materializes it from the
# SKYPHUSION_WRANGLER_TOML Actions secret (see scripts/materialize-config.mjs).
#
# Secrets (wrangler secret put):
#   MCP_TOKEN — comma-separated per-consumer tokens, e.g.:
#     alice=...,bob=...

name = "crew-bus"
main = "src/index.ts"
compatibility_date = "2026-06-01"

preview_urls = false
workers_dev = false

[observability]
enabled = true

[[d1_databases]]
binding = "DB"
database_name = "crew-bus"
database_id = "REPLACE_WITH_D1_ID"

[triggers]
crons = ["0 4 * * *"]

[vars]
RETENTION_DAYS = "30"

# Optional custom domain (or use workers.dev / your own tunnel):
# [[routes]]
# pattern = "crew-bus.example.com"
# custom_domain = true
