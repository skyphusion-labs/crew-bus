# crew-bus Worker — wrangler config example.
# Copy to wrangler.toml and fill D1 database_id after: wrangler d1 create crew-bus
#
# Production config is NOT committed. CI materializes it from the
# SKYPHUSION_WRANGLER_TOML Actions secret (see scripts/materialize-config.mjs).
#
# Secrets (wrangler secret put):
#   MCP_TOKEN — comma-separated per-consumer tokens, e.g.:
#     alice=...,bob=...
#   <AUTH_ENV_NAME> -- optional per-webhook Authorization value; a webhook row's
#     auth_env NAMES this binding (real credential stays in wrangler secrets).

name = "crew-bus"
main = "src/index.ts"
compatibility_date = "2026-06-01"

preview_urls = false
workers_dev = false

[observability]
enabled = true

[[d1_databases]]
binding = "DB"
database_name = "crew-bus"
database_id = "REPLACE_WITH_D1_ID"

# #40 doorbell VPC muxes (optional): a Workers VPC service per box fronting a tiny
# doorbell mux, so fleet seats need no public hooks-* tunnel. The binding NAME must
# match VPC_DOORBELL_BINDINGS in src/env.ts and the webhook row target. Add one
# stanza per box mux once its VPC service exists (service_id from the VPC service).
# [[vpc_services]]
# binding = "DISCHORD_DOORBELL_VPC"
# service_id = "REPLACE_WITH_VPC_SERVICE_ID"

[triggers]
crons = ["0 4 * * *"]

[vars]
RETENTION_DAYS = "30"

# Optional custom domain (or use workers.dev / your own tunnel):
# [[routes]]
# pattern = "crew-bus.example.com"
# custom_domain = true
